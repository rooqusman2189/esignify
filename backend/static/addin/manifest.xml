<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>e1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.1</Version>
  <ProviderName>ESignify</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="ESignify Signatures"/>
  <Description DefaultValue="Insert your organization email signature into emails."/>
  <IconUrl DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/icon-64.png"/>
  <SupportUrl DefaultValue="https://esignify-preview-1.preview.emergentagent.com"/>
  
  <AppDomains>
    <AppDomain>https://esignify-preview-1.preview.emergentagent.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="FunctionFile"/>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeCmdGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="insertSignatureBtn">
                  <Label resid="BtnLabel"/>
                  <Supertip>
                    <Title resid="BtnTitle"/>
                    <Description resid="BtnDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="TaskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/icon-16.png"/>
        <bt:Image id="Icon32" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/icon-32.png"/>
        <bt:Image id="Icon80" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="TaskpaneUrl" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/taskpane.html"/>
        <bt:Url id="FunctionFile" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="ESignify"/>
        <bt:String id="BtnLabel" DefaultValue="Insert Signature"/>
        <bt:String id="BtnTitle" DefaultValue="Insert Signature"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="BtnDesc" DefaultValue="Insert your organization email signature into the email body"/>
      </bt:LongStrings>
    </Resources>

    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.5">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <FunctionFile resid="FunctionFile"/>
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeCmdGroupV11">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="insertSignatureBtnV11">
                    <Label resid="BtnLabel"/>
                    <Supertip>
                      <Title resid="BtnTitle"/>
                      <Description resid="BtnDesc"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon16"/>
                      <bt:Image size="32" resid="Icon32"/>
                      <bt:Image size="80" resid="Icon80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="TaskpaneUrl"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>

          <MobileFormFactor>
            <FunctionFile resid="FunctionFile"/>
            <ExtensionPoint xsi:type="MobileMessageComposeCommandSurface">
              <Group id="mobileMsgComposeCmdGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="MobileButton" id="mobileInsertSignatureBtn">
                  <Label resid="BtnLabel"/>
                  <Icon>
                    <bt:Image size="25" scale="1" resid="Icon32"/>
                    <bt:Image size="25" scale="2" resid="Icon32"/>
                    <bt:Image size="25" scale="3" resid="Icon32"/>
                    <bt:Image size="32" scale="1" resid="Icon32"/>
                    <bt:Image size="32" scale="2" resid="Icon32"/>
                    <bt:Image size="32" scale="3" resid="Icon32"/>
                    <bt:Image size="48" scale="1" resid="Icon80"/>
                    <bt:Image size="48" scale="2" resid="Icon80"/>
                    <bt:Image size="48" scale="3" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="TaskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </ExtensionPoint>
          </MobileFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon16" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/icon-16.png"/>
          <bt:Image id="Icon32" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/icon-32.png"/>
          <bt:Image id="Icon80" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="TaskpaneUrl" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/taskpane.html"/>
          <bt:Url id="FunctionFile" DefaultValue="https://esignify-preview-1.preview.emergentagent.com/api/static/addin/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="ESignify"/>
          <bt:String id="BtnLabel" DefaultValue="Insert Signature"/>
          <bt:String id="BtnTitle" DefaultValue="Insert Signature"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="BtnDesc" DefaultValue="Insert your organization email signature into the email body"/>
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
